{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Transform": "AWS::Serverless-2016-10-31",
  "Description": "Books Search API - REST API Gateway with Lambda authorizer",
  "Parameters": {
    "AuthTokenValue": {
      "Type": "String",
      "NoEcho": true,
      "Description": "Secret token value for the x-api-token header"
    },
    "StageName": {
      "Type": "String",
      "Default": "test",
      "Description": "API Gateway stage name"
    }
  },
  "Globals": {
    "Function": {
      "Timeout": 10,
      "Runtime": "python3.12",
      "MemorySize": 128
    }
  },
  "Resources": {
    "BooksApi": {
      "Type": "AWS::Serverless::Api",
      "Properties": {
        "StageName": { "Ref": "StageName" },
        "EndpointConfiguration": {
          "Type": "REGIONAL"
        },
        "Auth": {
          "DefaultAuthorizer": "TokenAuthorizer",
          "Authorizers": {
            "TokenAuthorizer": {
              "FunctionArn": { "Fn::GetAtt": ["AuthorizerFunction", "Arn"] },
              "Identity": {
                "Header": "x-api-token"
              }
            }
          }
        }
      }
    },

    "AuthorizerFunction": {
      "Type": "AWS::Serverless::Function",
      "Properties": {
        "Handler": "authorizer.handler",
        "CodeUri": "src/",
        "Description": "Lambda authorizer - validates x-api-token header",
        "Environment": {
          "Variables": {
            "AUTH_TOKEN": { "Ref": "AuthTokenValue" }
          }
        }
      }
    },
    "ListBooksFunction": {
      "Type": "AWS::Serverless::Function",
      "Properties": {
        "Handler": "app.list_books",
        "CodeUri": "src/",
        "Description": "Returns all books",
        "Events": {
          "ListBooks": {
            "Type": "Api",
            "Properties": {
              "RestApiId": { "Ref": "BooksApi" },
              "Path": "/books",
              "Method": "GET"
            }
          }
        }
      }
    },
    "GetBookFunction": {
      "Type": "AWS::Serverless::Function",
      "Properties": {
        "Handler": "app.get_book",
        "CodeUri": "src/",
        "Description": "Returns a single book by ID",
        "Events": {
          "GetBook": {
            "Type": "Api",
            "Properties": {
              "RestApiId": { "Ref": "BooksApi" },
              "Path": "/books/{bookId}",
              "Method": "GET"
            }
          }
        }
      }
    },
    "GetRootFunction": {
      "Type": "AWS::Serverless::Function",
      "Properties": {
        "Handler": "app.get_root",
        "CodeUri": "src/",
        "Description": "Returns API overview",
        "Events": {
          "Root": {
            "Type": "Api",
            "Properties": {
              "RestApiId": { "Ref": "BooksApi" },
              "Path": "/",
              "Method": "GET"
            }
          }
        }
      }
    }
  },
  "Outputs": {
    "BooksApiUrl": {
      "Description": "API Gateway endpoint URL (use HTTPS only)",
      "Value": {
        "Fn::Sub": "https://${BooksApi}.execute-api.${AWS::Region}.amazonaws.com/${StageName}/"
      }
    },
    "BooksApiId": {
      "Description": "API Gateway ID",
      "Value": { "Ref": "BooksApi" }
    }
  }
}
