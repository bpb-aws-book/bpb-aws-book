{
	"AWSTemplateFormatVersion": "2010-09-09",
	"Transform": "AWS::Serverless-2016-10-31",
	"Description": "Bedrock API Tutorial - Demonstrates differences between InvokeModel and Converse APIs, and the impact of inference parameters (temperature, topP, topK).",
	"Globals": {
		"Function": {
			"Runtime": "python3.12",
			"Timeout": 180,
			"MemorySize": 256,
			"Architectures": [
				"x86_64"
			]
		}
	},
	"Resources": {
		"BedrockAccessPolicy": {
			"Type": "AWS::IAM::ManagedPolicy",
			"Properties": {
				"Description": "Allows Lambda functions to invoke Bedrock models",
				"PolicyDocument": {
					"Version": "2012-10-17",
					"Statement": [
						{
							"Effect": "Allow",
							"Action": [
								"bedrock:InvokeModel",
								"bedrock:InvokeModelWithResponseStream"
							],
							"Resource": "*"
						},
						{
							"Effect": "Allow",
							"Action": [
								"aws-marketplace:ViewSubscriptions",
								"aws-marketplace:Subscribe"
							],
							"Resource": "*"
						}
					]
				}
			}
		},
		"InvokeVsConverseDemo": {
			"Type": "AWS::Serverless::Function",
			"Properties": {
				"FunctionName": "BedrockInvokeVsConverseDemo",
				"Handler": "lambda_function.lambda_handler",
				"CodeUri": "src/invoke_vs_converse/",
				"Description": "Demonstrates InvokeModel (model-specific schemas) vs Converse (unified schema)",
				"Policies": [
					{"Ref": "BedrockAccessPolicy"}
				]
			}
		},
		"StreamingDemo": {
			"Type": "AWS::Serverless::Function",
			"Properties": {
				"FunctionName": "BedrockStreamingDemo",
				"Handler": "lambda_function.lambda_handler",
				"CodeUri": "src/streaming_vs_nonstreaming/",
				"Description": "Demonstrates streaming vs non-streaming with InvokeModel and Converse APIs",
				"Policies": [
					{"Ref": "BedrockAccessPolicy"}
				]
			}
		},
		"InferenceParamsDemo": {
			"Type": "AWS::Serverless::Function",
			"Properties": {
				"FunctionName": "BedrockInferenceParamsDemo",
				"Handler": "lambda_function.lambda_handler",
				"CodeUri": "src/inference_params/",
				"Description": "Demonstrates the impact of temperature, topP, and topK on model output",
				"Policies": [
					{"Ref": "BedrockAccessPolicy"}
				]
			}
		}
	},
	"Outputs": {
		"InvokeVsConverseDemoFunction": {
			"Description": "InvokeModel vs Converse Demo Lambda Function ARN",
			"Value": {"Fn::GetAtt": ["InvokeVsConverseDemo", "Arn"]}
		},
		"StreamingDemoFunction": {
			"Description": "Streaming Demo Lambda Function ARN",
			"Value": {"Fn::GetAtt": ["StreamingDemo", "Arn"]}
		},
		"InferenceParamsDemoFunction": {
			"Description": "Inference Params Demo Lambda Function ARN",
			"Value": {"Fn::GetAtt": ["InferenceParamsDemo", "Arn"]}
		}
	}
}
